---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const frameworks = (await getCollection('frameworks')).sort(
  (a, b) => a.data.number - b.data.number
);

const stages = [
  {
    slug: 'user-insight',
    name: '使用者洞察',
    icon: '01',
    desc: '深入理解使用者的行為、動機和需求。',
    color: '#60a5fa',
    bg: '#1a2332',
  },
  {
    slug: 'problem-definition',
    name: '問題定義',
    icon: '02',
    desc: '把模糊的需求轉化為清晰的問題陳述。',
    color: '#f87171',
    bg: '#2a1a1a',
  },
  {
    slug: 'ideation',
    name: '創意發想',
    icon: '03',
    desc: '系統化地產生解決方案。',
    color: '#4ade80',
    bg: '#1a2a1a',
  },
  {
    slug: 'validation',
    name: '驗證測試',
    icon: '04',
    desc: '用最小成本驗證假設。',
    color: '#fbbf24',
    bg: '#2a2a1a',
  },
  {
    slug: 'execution',
    name: '執行落地',
    icon: '05',
    desc: '把想法變成可交付的成果。',
    color: '#818cf8',
    bg: '#1a1a2a',
  },
  {
    slug: 'growth',
    name: '成長策略',
    icon: '06',
    desc: '系統化地驅動產品成長。',
    color: '#e879f9',
    bg: '#2a1a2a',
  },
  {
    slug: 'systems-thinking',
    name: '系統思維',
    icon: '07',
    desc: '跳出局部優化，看到全局。',
    color: '#2dd4bf',
    bg: '#1a2a2a',
  },
];

const categoryMap: Record<string, string> = {
  '使用者洞察': 'user-insight',
  '問題定義': 'problem-definition',
  '創意發想': 'ideation',
  '驗證測試': 'validation',
  '執行落地': 'execution',
  '成長策略': 'growth',
  '系統思維': 'systems-thinking',
};

const stageFrameworks = stages.map((stage) => ({
  ...stage,
  frameworks: frameworks.filter((f) => f.data.category === stage.name),
}));

const jsonLd = {
  '@type': 'CollectionPage',
  name: '產品開發路線圖 — PMFrame.works',
  description: '從使用者洞察到系統思維，七個階段帶你走完產品開發全流程，找到每個階段最適合的框架。',
  url: new URL('/roadmap', Astro.site).toString(),
};
---

<BaseLayout
  title="產品開發路線圖 · PMFrame.works 繁中版"
  description="從使用者洞察到系統思維，七個階段帶你走完產品開發全流程，找到每個階段最適合的框架。"
  jsonLd={jsonLd}
>
  <Header showBack={true} subtitle="路線圖" />

  <section class="roadmap-hero">
    <div class="container">
      <p class="hero-eyebrow">產品開發旅程</p>
      <h1 class="hero-title">
        路線<em>圖</em>
      </h1>
      <p class="hero-desc">
        不確定該用哪個框架？從你目前所在的階段開始，<br />
        沿著路線圖找到最適合的工具。
      </p>
    </div>
  </section>

  <!-- Timeline navigation -->
  <nav class="timeline-nav">
    <div class="container">
      <div class="timeline-track">
        {stages.map((stage, i) => (
          <a href={`#stage-${stage.slug}`} class="timeline-dot" style={`--dot-color: ${stage.color}`}>
            <span class="dot-number">{stage.icon}</span>
            <span class="dot-label">{stage.name}</span>
          </a>
        ))}
        <div class="timeline-line" aria-hidden="true"></div>
      </div>
    </div>
  </nav>

  <!-- Stage sections -->
  <div class="stages">
    {stageFrameworks.map((stage, i) => (
      <section class="stage" id={`stage-${stage.slug}`}>
        <div class="container">
          <div class="stage-header">
            <div class="stage-indicator" style={`--stage-color: ${stage.color}; --stage-bg: ${stage.bg}`}>
              <span class="stage-number">{stage.icon}</span>
              <div class="stage-meta">
                <h2 class="stage-title">{stage.name}</h2>
                <p class="stage-desc">{stage.desc}</p>
              </div>
              <span class="stage-count">{stage.frameworks.length} 個框架</span>
            </div>
            {i < stages.length - 1 && <div class="stage-arrow" aria-hidden="true"></div>}
          </div>

          <div class="stage-grid">
            {stage.frameworks.map((f) => (
              <a href={`/frameworks/${f.id}/`} class="mini-card" style={`--card-accent: ${stage.color}; --card-bg: ${stage.bg}`}>
                <span class="mini-number">#{String(f.data.number).padStart(2, '0')}</span>
                <span class="mini-title">{f.data.title}</span>
                <span class="mini-en">{f.data.titleEn}</span>
              </a>
            ))}
          </div>

          <a href={`/category/${stage.slug}/`} class="stage-more" style={`color: ${stage.color}`}>
            查看全部 {stage.name} 框架 &rarr;
          </a>
        </div>
      </section>
    ))}
  </div>

  <Footer />
</BaseLayout>

<style>
  /* Hero */
  .roadmap-hero {
    padding: var(--space-3xl) 0 var(--space-xl);
    text-align: center;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 300;
    line-height: 1.2;
    margin-bottom: var(--space-lg);
  }

  .hero-title em {
    font-weight: 600;
    font-style: italic;
  }

  .hero-desc {
    font-size: 1rem;
    color: var(--text-muted);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.8;
  }

  /* Timeline navigation */
  .timeline-nav {
    padding: var(--space-xl) 0;
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 10;
    border-bottom: 1px solid var(--border);
  }

  .timeline-track {
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    padding: 0 var(--space-md);
  }

  .timeline-line {
    position: absolute;
    top: 50%;
    left: var(--space-md);
    right: var(--space-md);
    height: 2px;
    background: var(--border);
    transform: translateY(-50%);
    z-index: 0;
  }

  .timeline-dot {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    z-index: 1;
    text-decoration: none;
    transition: transform 0.2s;
  }

  .timeline-dot:hover {
    transform: translateY(-2px);
  }

  .dot-number {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--dot-color);
    color: var(--dot-color);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 500;
    transition: all 0.2s;
  }

  .timeline-dot:hover .dot-number {
    background: var(--dot-color);
    color: var(--bg);
  }

  .dot-label {
    font-size: 0.65rem;
    color: var(--text-dim);
    white-space: nowrap;
    transition: color 0.2s;
  }

  .timeline-dot:hover .dot-label {
    color: var(--dot-color);
  }

  /* Stage sections */
  .stages {
    padding: var(--space-xl) 0;
  }

  .stage {
    padding: var(--space-2xl) 0;
  }

  .stage-header {
    margin-bottom: var(--space-xl);
  }

  .stage-indicator {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-xl);
    background: var(--stage-bg);
    border: 1px solid color-mix(in srgb, var(--stage-color) 30%, transparent);
    border-radius: var(--radius);
  }

  .stage-number {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--stage-color);
    flex-shrink: 0;
  }

  .stage-meta {
    flex: 1;
  }

  .stage-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--stage-color);
    margin-bottom: var(--space-xs);
  }

  .stage-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .stage-count {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    flex-shrink: 0;
  }

  .stage-arrow {
    width: 2px;
    height: 24px;
    background: var(--border);
    margin: var(--space-md) auto;
    position: relative;
  }

  .stage-arrow::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 50%;
    transform: translateX(-50%);
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid var(--border);
  }

  /* Mini cards grid */
  .stage-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .mini-card {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-md);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    transition: all 0.2s;
    text-decoration: none;
  }

  .mini-card:hover {
    border-color: var(--card-accent);
    background: var(--card-bg);
    transform: translateY(-1px);
  }

  .mini-number {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-dim);
  }

  .mini-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
  }

  .mini-en {
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  .stage-more {
    font-size: 0.85rem;
    font-weight: 500;
    transition: opacity 0.2s;
  }

  .stage-more:hover {
    opacity: 0.8;
  }

  /* Light mode overrides */
  :global([data-theme="light"]) .stage-indicator {
    background: color-mix(in srgb, var(--stage-color) 8%, white);
    border-color: color-mix(in srgb, var(--stage-color) 25%, transparent);
  }

  :global([data-theme="light"]) .mini-card:hover {
    background: color-mix(in srgb, var(--card-accent) 6%, white);
  }

  :global([data-theme="light"]) .dot-number {
    background: var(--bg);
  }

  :global([data-theme="light"]) .timeline-dot:hover .dot-number {
    color: white;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .timeline-nav {
      overflow-x: auto;
    }

    .timeline-track {
      min-width: 600px;
    }

    .stage-indicator {
      flex-wrap: wrap;
      gap: var(--space-sm);
      padding: var(--space-md);
    }

    .stage-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
