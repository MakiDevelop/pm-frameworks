---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FrameworkCard from '../../components/FrameworkCard.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const frameworks = await getCollection('frameworks');
  return frameworks.map((f) => ({
    params: { id: f.id },
    props: { framework: f, allFrameworks: frameworks },
  }));
}

const { framework, allFrameworks } = Astro.props;
const { Content } = await render(framework);
const { number, title, titleEn, category, oneLiner, author, source, stage, duration, year, similarTo } = framework.data;
const num = String(number).padStart(2, '0');
const skillPath = `/skills/${framework.id}.md`;

// Related frameworks (same category, exclude self, max 4)
const related = allFrameworks
  .filter((f) => f.data.category === category && f.id !== framework.id)
  .sort((a, b) => a.data.number - b.data.number)
  .slice(0, 4);

// Similar frameworks (for comparison section)
const similarFrameworks = (similarTo || []).map((s) => {
  const match = allFrameworks.find((f) => f.id === s.slug);
  return match ? { ...s, title: match.data.title, titleEn: match.data.titleEn } : null;
}).filter(Boolean) as { slug: string; difference: string; title: string; titleEn: string }[];

// Category slug mapping
const categorySlugMap: Record<string, string> = {
  '使用者洞察': 'user-insight',
  '問題定義': 'problem-definition',
  '創意發想': 'ideation',
  '驗證測試': 'validation',
  '執行落地': 'execution',
  '成長策略': 'growth',
  '系統思維': 'systems-thinking',
};

// JSON-LD structured data
const jsonLd = [
  {
    '@type': 'TechArticle',
    headline: `${title} (${titleEn})`,
    alternativeHeadline: titleEn,
    description: oneLiner,
    author: { '@type': 'Person', name: author },
    publisher: { '@type': 'Organization', name: 'pm.maki.tw' },
    datePublished: `${year}-01-01`,
    articleSection: category,
    inLanguage: 'zh-TW',
    url: new URL(Astro.url.pathname, Astro.site).toString(),
  },
  {
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: `${title}（${titleEn}）是什麼？`,
        acceptedAnswer: {
          '@type': 'Answer',
          text: oneLiner,
        },
      },
      {
        '@type': 'Question',
        name: `${title} 適合什麼時候使用？`,
        acceptedAnswer: {
          '@type': 'Answer',
          text: `${title} 適用於 ${stage} 階段，通常需要 ${duration}。由 ${author} 提出。`,
        },
      },
    ],
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: '首頁', item: new URL('/', Astro.site).toString() },
      { '@type': 'ListItem', position: 2, name: category, item: new URL(`/category/${categorySlugMap[category]}/`, Astro.site).toString() },
      { '@type': 'ListItem', position: 3, name: title },
    ],
  },
];
---

<BaseLayout title={`${title}（${titleEn}）· PMFrame.works`} description={oneLiner} jsonLd={jsonLd}>
  <Header showBack={true} subtitle={`${category} · #${num}`} />

  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="麵包屑導覽">
    <div class="container">
      <a href="/">首頁</a>
      <span class="breadcrumb-sep">/</span>
      <a href={`/category/${categorySlugMap[category]}/`}>{category}</a>
      <span class="breadcrumb-sep">/</span>
      <span>{title}</span>
    </div>
  </nav>

  <article class="framework-detail">
    <div class="container">
      <section class="detail-hero">
        <span class="detail-eyebrow">Framework Deep Dive</span>
        <h1 class="detail-title">
          {title} <em>{titleEn}</em>
        </h1>
        <p class="detail-oneliner">{oneLiner}</p>

        <!-- Metadata as dl for AIO -->
        <div class="detail-meta">
          <dl class="meta-grid">
            <div class="meta-item">
              <dt class="meta-label">提出者</dt>
              <dd class="meta-value">{author}</dd>
            </div>
            <div class="meta-item">
              <dt class="meta-label">來源</dt>
              <dd class="meta-value">{source}</dd>
            </div>
            <div class="meta-item">
              <dt class="meta-label">適合階段</dt>
              <dd class="meta-value">{stage}</dd>
            </div>
            <div class="meta-item">
              <dt class="meta-label">使用時長</dt>
              <dd class="meta-value">{duration}</dd>
            </div>
          </dl>
          <a href={skillPath} class="skill-download" download>
            &#x2B07; 下載 Skill
          </a>
        </div>
      </section>

      <section class="detail-content">
        <Content />
      </section>

      <!-- Similar Frameworks (Comparison) -->
      {similarFrameworks.length > 0 && (
        <section class="similar-section">
          <h2 class="similar-title">容易搞混？</h2>
          <p class="similar-subtitle">這些框架看起來很像，但用途不同。</p>
          <div class="similar-list">
            {similarFrameworks.map((s) => (
              <a href={`/frameworks/${s.slug}/`} class="similar-item">
                <div class="similar-header">
                  <span class="similar-vs">vs</span>
                  <span class="similar-name">{s.title}</span>
                  <span class="similar-en">{s.titleEn}</span>
                </div>
                <p class="similar-diff">{s.difference}</p>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Related Frameworks -->
      {related.length > 0 && (
        <section class="related-section">
          <h2 class="related-title">同類框架推薦</h2>
          <div class="related-grid">
            {related.map((f) => (
              <FrameworkCard
                number={f.data.number}
                title={f.data.title}
                titleEn={f.data.titleEn}
                category={f.data.category}
                oneLiner={f.data.oneLiner}
                slug={f.id}
              />
            ))}
          </div>
        </section>
      )}
    </div>
  </article>

  <Footer />
</BaseLayout>

<style>
  .breadcrumb {
    padding: var(--space-md) 0;
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  .breadcrumb a {
    color: var(--text-dim);
  }

  .breadcrumb a:hover {
    color: var(--accent);
  }

  .breadcrumb-sep {
    margin: 0 var(--space-sm);
  }

  .framework-detail {
    padding: var(--space-2xl) 0;
  }

  .detail-hero {
    max-width: var(--max-content);
    margin: 0 auto var(--space-3xl);
    text-align: center;
  }

  .detail-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .detail-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 300;
    line-height: 1.2;
    margin: var(--space-md) 0;
  }

  .detail-title em {
    font-weight: 600;
    font-style: italic;
    color: var(--text-muted);
    font-size: 0.6em;
    display: block;
    margin-top: var(--space-xs);
  }

  .detail-oneliner {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 600px;
    margin: 0 auto var(--space-xl);
    line-height: 1.7;
  }

  .detail-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-lg);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .meta-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-lg);
  }

  .meta-item {
    text-align: center;
  }

  .meta-label {
    display: block;
    font-size: 0.7rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.2em;
  }

  .meta-value {
    font-size: 0.85rem;
    color: var(--text);
  }

  .detail-content {
    max-width: var(--max-content);
    margin: 0 auto;
  }

  .detail-content :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    margin: var(--space-3xl) 0 var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--border);
  }

  .detail-content :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin: var(--space-xl) 0 var(--space-md);
  }

  .detail-content :global(p) {
    margin-bottom: var(--space-md);
    color: var(--text-muted);
    line-height: 1.8;
  }

  .detail-content :global(ul),
  .detail-content :global(ol) {
    margin-bottom: var(--space-md);
    padding-left: var(--space-lg);
    color: var(--text-muted);
  }

  .detail-content :global(li) {
    margin-bottom: var(--space-sm);
    line-height: 1.7;
  }

  .detail-content :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .detail-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: var(--space-lg);
    margin: var(--space-xl) 0;
    color: var(--text-muted);
    font-style: italic;
  }

  .detail-content :global(.maki-take) {
    background: var(--maki-bg);
    border: 1px solid var(--maki-border);
    border-radius: var(--radius);
    padding: var(--space-xl);
    margin: var(--space-xl) 0;
  }

  .detail-content :global(.maki-take-label) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--maki-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-sm);
  }

  .detail-content :global(.do-box) {
    background: #0d1f0d;
    border: 1px solid #1a3a1a;
    border-radius: var(--radius);
    padding: var(--space-lg);
    margin: var(--space-md) 0;
  }

  .detail-content :global(.dont-box) {
    background: #1f0d0d;
    border: 1px solid #3a1a1a;
    border-radius: var(--radius);
    padding: var(--space-lg);
    margin: var(--space-md) 0;
  }

  /* Similar Frameworks (Comparison) */
  .similar-section {
    max-width: var(--max-content);
    margin: var(--space-3xl) auto 0;
    padding: var(--space-xl);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .similar-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: var(--space-xs);
    color: var(--amber);
  }

  .similar-subtitle {
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: var(--space-lg);
  }

  .similar-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .similar-item {
    display: block;
    padding: var(--space-md) var(--space-lg);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    transition: all 0.2s;
    text-decoration: none;
  }

  .similar-item:hover {
    border-color: var(--amber);
    background: #1a1a14;
  }

  .similar-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .similar-vs {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--amber);
    background: #2a2a1a;
    padding: 0.15em 0.5em;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .similar-name {
    font-weight: 600;
    color: var(--text);
    font-size: 0.95rem;
  }

  .similar-en {
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  .similar-diff {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .related-section {
    max-width: var(--max-content);
    margin: var(--space-3xl) auto 0;
  }

  .related-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: var(--space-lg);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: var(--space-md);
  }

  @media (max-width: 640px) {
    .meta-grid {
      flex-direction: column;
    }
  }
</style>
